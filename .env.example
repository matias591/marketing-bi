# ============================================================
# Marketing BI — environment variables
# Copy to .env.local for local dev. Set these in Vercel for prod.
# ============================================================

# --- Supabase (project URL + keys from Supabase Studio → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-only, NEVER exposed to client. Used by:
#  - the cron sync handler (write to raw.* / ops.*)
#  - the admin invite flow (invite users)
#  - the first-admin seed migration
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database connection (Supavisor TRANSACTION-mode pooler, port 6543) ---
# Format: postgresql://postgres.{ref}:{db-password}@aws-0-{region}.pooler.supabase.com:6543/postgres
# CRITICAL: must be port 6543 (transaction mode), not 5432 (session mode).
# CRITICAL: in app code, the postgres driver is configured with prepare:false and max:1.
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PWD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used ONLY for drizzle-kit migrations from a developer laptop.
# Never used at runtime. Pulled from Supabase Studio → Connect → "Direct connection".
DIRECT_DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PWD@db.YOUR_REF.supabase.co:5432/postgres

# --- Salesforce (OAuth 2.0 JWT Bearer Flow) ---
# From the Connected App in Salesforce Setup → App Manager.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your-connected-app-consumer-key
SF_USERNAME=integration-user@orca-ai.io

# Path to the private key file (matching the public cert uploaded to the Connected App).
# Local dev: store at sf-jwt.private.pem (gitignored).
# Vercel: paste the PEM contents into SF_PRIVATE_KEY env var (with literal \n).
SF_PRIVATE_KEY_PATH=./sf-jwt.private.pem
SF_PRIVATE_KEY=

# --- Cron secret ---
# Vercel calls /api/cron/* with `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-with-random-string

# --- Project ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
BUSINESS_TIMEZONE=America/New_York
ALLOWED_EMAIL_DOMAIN=orca-ai.io
FIRST_ADMIN_EMAIL=matias@orca-ai.io
